    {
      "id": "configure",
      "template": "login_credentials",
      "options": {
        "logo": "../assets/icon.svg",
        "title": {
          "en": "Configure Inverter Connection"
        },
        "usernameLabel": {
          "en": "Inverter Host (IP Address)"
        },
        "usernamePlaceholder": {
          "en": "e.g. 192.168.1.100"
        },
        "passwordLabel": {
          "en": "Data Logger Serial Number"
        },
        "passwordPlaceholder": {
          "en": "e.g. 1234567890"
        }
      }
    },
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": {
        "next": "add_devices"
      }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ],
